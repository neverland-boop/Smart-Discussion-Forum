<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.LoginController">
   <children>
      <HBox layoutX="0.0" layoutY="0.0" prefHeight="700.0" prefWidth="1000.0" spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
            <!-- Left branding panel — same green identity as the rest of the app -->
            <VBox alignment="TOP_CENTER" prefWidth="400.0" spacing="20.0" styleClass="brand-panel" HBox.hgrow="ALWAYS">
               <padding>
                  <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
               </padding>
               <children>
                  <Label styleClass="brand-title" text="SMART&#10;DISCUSSION FORUM" textAlignment="CENTER">
                     <font>
                        <Font name="System Bold" size="26.0" />
                     </font>
                  </Label>
                  <Label styleClass="brand-sub" text="Share. Learn. Grow Together." />
                  <Label styleClass="brand-title" text="Students Login">
                     <font>
                        <Font name="System Bold" size="22.0" />
                     </font>
                  </Label>
                  <Label styleClass="brand-title" text="Connect, Discuss, Succeed." />
               </children>
            </VBox>

            <!-- Right form panel -->
            <VBox alignment="CENTER_LEFT" prefWidth="500.0" spacing="15.0" styleClass="left-panel" HBox.hgrow="ALWAYS">
               <padding>
                  <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
               </padding>
               <children>
                  <Label styleClass="big-bold" text="Welcome Back!">
                     <font>
                        <Font size="28.0" />
                     </font>
                  </Label>
                  <Label text="Login to continue to your account" />

                  <Label styleClass="big-bold" text="Email">
                     <font>
                        <Font size="13.0" />
                     </font>
                  </Label>
                  <TextField fx:id="emailField" prefHeight="45.0" promptText="Enter your email" />

                  <Label styleClass="big-bold" text="Password">
                     <font>
                        <Font size="13.0" />
                     </font>
                  </Label>
                  <PasswordField fx:id="passwordField" prefHeight="45.0" promptText="Enter your password" />

                  <HBox alignment="CENTER_LEFT" spacing="120.0">
                     <children>
                        <CheckBox fx:id="rememberMe" text="Remember me" />
                        <Hyperlink text="Forgot Password?" />
                     </children>
                  </HBox>

                  <Button onAction="#handleLoginAction" prefHeight="50.0" prefWidth="420.0" styleClass="button" text="Login" />

                  <HBox alignment="CENTER" spacing="10.0">
                     <children>
                        <Label text="Don't have an account?" />
                        <Hyperlink onAction="#handleGoToRegister" text="Register here" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</AnchorPane>
