<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" stylesheets="@view/style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.Reg">
   <children>
      <HBox layoutX="-2.0" layoutY="2.0" prefHeight="630.0" prefWidth="764.0">
         <children>
            <VBox prefHeight="600.0" prefWidth="825.0" styleClass="left-panel" stylesheets="@view/style.css">
               <padding>
                  <Insets left="10.0" right="20.0" top="10.0" />
               </padding>
               <children>
                  <Label alignment="CENTER_RIGHT" prefHeight="90.0" prefWidth="348.0" styleClass="big-bold" text="Registration declined" textFill="#f52828">
                     <font>
                        <Font size="24.0" />
                     </font>
                  </Label>
                  <Label prefHeight="66.0" prefWidth="523.0" text="You must accept the platform rules and guidelines">
                     <font>
                        <Font size="16.0" />
                     </font></Label>
                  <Label prefHeight="16.0" prefWidth="321.0" text="before using the Smart Discussion Forum">
                     <font>
                        <Font size="16.0" />
                     </font></Label>
                  <HBox prefHeight="100.0" prefWidth="200.0">
                     <children>
                        <Label prefHeight="115.0" prefWidth="75.0" text="Click here to" />
                        <Hyperlink onAction="#handleReturnToLogin" prefHeight="101.0" prefWidth="170.0" text="Return to Register" underline="true" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
         <padding>
            <Insets left="30.0" right="30.0" top="30.0" />
         </padding>
      </HBox>
   </children>
</AnchorPane>
