<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.QuizController"
            prefWidth="900"
            prefHeight="600">

    <top>
        <HBox spacing="30"
              alignment="CENTER"
              style="-fx-background-color: #1f4e78; -fx-padding: 15;">

            <Label text="QUIZ"
                   style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>

            <Label fx:id="timerLabel"
                   text="Time: 10:00"
                   style="-fx-text-fill: white; -fx-font-size: 18px;"/>

            <Label fx:id="violationLabel"
                   text="Violations: 0/3"
                   style="-fx-text-fill: white; -fx-font-size: 18px;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="18">

            <padding>
                <Insets top="25"
                        right="25"
                        bottom="25"
                        left="25"/>
            </padding>

            <Label fx:id="questionNumberLabel"
                   text="Question 1"
                   style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <Label fx:id="questionTextLabel"
                   text="Question text will appear here."
                   wrapText="true"
                   style="-fx-font-size: 20px;"/>

            <fx:define>
                <ToggleGroup fx:id="answerGroup"/>
            </fx:define>

            <RadioButton fx:id="optionA"
                         text="Option A"
                         toggleGroup="$answerGroup"/>

            <RadioButton fx:id="optionB"
                         text="Option B"
                         toggleGroup="$answerGroup"/>

            <RadioButton fx:id="optionC"
                         text="Option C"
                         toggleGroup="$answerGroup"/>

            <RadioButton fx:id="optionD"
                         text="Option D"
                         toggleGroup="$answerGroup"/>

        </VBox>
    </center>

    <bottom>
        <HBox spacing="20"
              alignment="CENTER_RIGHT">

            <padding>
                <Insets top="20"
                        right="20"
                        bottom="20"
                        left="20"/>
            </padding>

            <Button fx:id="nextButton"
                    text="Next Question"
                    onAction="#nextQuestion"/>

            <Button text="Submit Quiz"
                    onAction="#submitQuiz"
                    style="-fx-background-color: #1f4e78; -fx-text-fill: white;"/>
        </HBox>
    </bottom>

</BorderPane>